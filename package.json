{
  "name": "seeker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:server": "tsx server/index.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed:fresh": "tsx server/db/seeds/seed.fresh.ts",
    "db:seed:active": "tsx server/db/seeds/seed.active.ts",
    "db:seed:demo": "tsx server/db/seeds/seed.demo.ts",
    "test": "jest",
    "test:e2e": "node -r dotenv/config ./node_modules/.bin/playwright test",
    "perf:api": "node -r dotenv/config ./node_modules/.bin/tsx scripts/measure-api.ts"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^4.16.0",
    "@aws-sdk/client-s3": "^3.1007.0",
    "@aws-sdk/s3-request-presigner": "^3.1007.0",
    "@tanstack/react-query": "^5.90.21",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.36",
    "express": "^4",
    "express-rate-limit": "^8.3.1",
    "multer": "^2.1.1",
    "next": "16.1.6",
    "pg": "^8",
    "pino": "^9",
    "pino-http": "^10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "redis": "^5.11.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^4",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20",
    "@types/pg": "^8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.28",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3",
    "ts-jest": "^29.4.6",
    "tsx": "^4",
    "typescript": "^5"
  }
