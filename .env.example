# Next.js / Auth0 (copy to .env.local for local dev)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000

# Express API (optional; server has defaults)
DATABASE_URL=
PORT=3001
# CORS allowed origin (default http://localhost:3000; set in prod to frontend URL)
# ALLOWED_ORIGIN=http://localhost:3000

# Redis (required; used for dashboard metrics cache)
REDIS_URL=redis://localhost:6379

# Express API auth (required for protected routes like GET /api/v1/me)
# Create an API in Auth0 Dashboard, set its identifier as AUTH0_AUDIENCE
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.auth0.com
AUTH0_AUDIENCE=

# Next.js proxy to Express (server-side; used by app/api/proxy)
EXPRESS_API_URL=http://localhost:3001

# Docker Compose (required when using docker-compose). Set POSTGRES_PASSWORD;
# POSTGRES_USER and POSTGRES_DB default to seeker if unset.
# POSTGRES_PASSWORD=

# Resumes (optional; required for POST/GET/DELETE /api/v1/resumes)
# Cloudflare R2. Create bucket and API token in R2 dashboard. Account ID from R2 URL.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_RESUMES=

# E2E (Playwright). Same Auth0 user as SEED_ACTIVE_AUTH0_ID. Not committed; set in .env only.
# E2E_AUTH_EMAIL=
# E2E_AUTH_PASSWORD=
